<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farever Region Editor</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #111; display: flex; height: 100vh; overflow: hidden; }
    #map { flex: 1; }
    .leaflet-container { background-image: url("fog.webp"); }

    /* ── Panel ── */
    #panel {
      width: 300px;
      background: #1e1a14;
      color: #e8dcc8;
      display: flex;
      flex-direction: column;
      border-left: 2px solid #4a3c28;
      flex-shrink: 0;
      overflow: hidden;
    }
    #panel h2 {
      background: linear-gradient(135deg, #785a37 50%, #8e6a41 50%);
      color: white;
      padding: 0.7em 0.9em;
      font-size: 0.95em;
      letter-spacing: 0.04em;
    }

    /* Add form */
    #add-form {
      padding: 0.75em 0.85em;
      border-bottom: 1px solid #3a2e1e;
      background: #251f15;
    }
    #add-form label { font-size: 0.78em; color: #a09070; display: block; margin-bottom: 0.2em; }
    #add-form input, #add-form select {
      width: 100%;
      padding: 0.4em 0.6em;
      background: #332a1a;
      border: 1px solid #5a4a2a;
      border-radius: 4px;
      color: #e8dcc8;
      font-size: 0.88em;
      margin-bottom: 0.5em;
    }
    #add-form input:focus, #add-form select:focus { outline: none; border-color: #a08040; }
    #add-form p {
      font-size: 0.75em;
      color: #7a6a50;
      margin-bottom: 0.5em;
      line-height: 1.4;
    }
    #mode-indicator {
      font-size: 0.78em;
      font-weight: bold;
      color: #f0a040;
      margin-bottom: 0.4em;
    }

    /* Label list */
    #label-list {
      flex: 1;
      overflow-y: auto;
      padding: 0.4em 0;
    }
    #label-list::-webkit-scrollbar { width: 4px; }
    #label-list::-webkit-scrollbar-thumb { background: #4a3c28; border-radius: 2px; }
    .label-item {
      display: flex;
      align-items: center;
      gap: 0.5em;
      padding: 0.45em 0.85em;
      border-bottom: 1px solid #2a2218;
      cursor: pointer;
      transition: background 0.1s;
    }
    .label-item:hover { background: #2a2218; }
    .label-item.selected { background: #3a2e1e; }
    .label-tier {
      font-size: 0.65em;
      font-weight: bold;
      padding: 0.15em 0.4em;
      border-radius: 3px;
      flex-shrink: 0;
      text-transform: uppercase;
    }
    .tier-region { background: #6e1ac7; color: white; }
    .tier-zone   { background: #388e9f; color: white; }
    .label-name { flex: 1; font-size: 0.85em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .del-btn {
      background: none;
      border: none;
      color: #c0392b;
      cursor: pointer;
      font-size: 1em;
      padding: 0 0.2em;
      flex-shrink: 0;
      opacity: 0.6;
    }
    .del-btn:hover { opacity: 1; }

    /* Footer */
    #footer {
      padding: 0.65em 0.85em;
      border-top: 1px solid #3a2e1e;
      display: flex;
      flex-direction: column;
      gap: 0.4em;
    }
    .btn {
      padding: 0.5em 0.9em;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 0.83em;
      font-weight: bold;
      width: 100%;
      transition: filter 0.15s;
    }
    .btn:hover { filter: brightness(1.15); }
    #btn-export { background: linear-gradient(135deg, #4c9da8 50%, #74babe 50%); color: white; }
    #btn-import { background: #332a1a; color: #e8dcc8; border: 1px solid #5a4a2a; }
    #btn-clear  { background: linear-gradient(135deg, #b0665d 50%, #ce715c 50%); color: white; }
    #status { font-size: 0.72em; color: #7a6a50; text-align: center; }

    /* Inline edit panel */
    #edit-panel {
      padding: 0.65em 0.85em;
      border-bottom: 1px solid #3a2e1e;
      background: #2a2218;
      display: none;
    }
    #edit-panel label { font-size: 0.75em; color: #a09070; display: block; margin-bottom: 0.2em; }
    #edit-panel input, #edit-panel select {
      width: 100%;
      padding: 0.35em 0.5em;
      background: #332a1a;
      border: 1px solid #5a4a2a;
      border-radius: 4px;
      color: #e8dcc8;
      font-size: 0.85em;
      margin-bottom: 0.4em;
    }
    #edit-panel input:focus, #edit-panel select:focus { outline: none; border-color: #a08040; }
    .edit-row { display: flex; gap: 0.4em; }
    .edit-row .btn { flex: 1; }
    #btn-edit-save { background: linear-gradient(135deg, #785a37 50%, #8e6a41 50%); color: white; }
    #btn-edit-cancel { background: #332a1a; color: #e8dcc8; border: 1px solid #5a4a2a; }
  </style>
</head>
<body>
<div id="map"></div>
<div id="panel">
  <h2>🗺 Region Editor</h2>

  <div id="add-form">
    <div id="mode-indicator">Click on the map to place a label</div>
    <label>Label text</label>
    <input id="inp-name" type="text" placeholder="e.g. Skover Island">
    <label>Type</label>
    <select id="inp-tier">
      <option value="region">Region (large, bold)</option>
      <option value="zone">Zone (smaller)</option>
    </select>
  </div>

  <div id="edit-panel">
    <label>Edit name</label>
    <input id="edit-name" type="text">
    <label>Type</label>
    <select id="edit-tier">
      <option value="region">Region</option>
      <option value="zone">Zone</option>
    </select>
    <div class="edit-row">
      <button class="btn" id="btn-edit-save">Save</button>
      <button class="btn" id="btn-edit-cancel">Cancel</button>
    </div>
  </div>

  <div id="label-list"></div>

  <div id="footer">
    <button class="btn" id="btn-export">⬇ Export regions.json</button>
    <button class="btn" id="btn-import">📂 Import regions.json</button>
    <button class="btn" id="btn-clear">🗑 Clear All</button>
    <div id="status">0 labels</div>
  </div>
</div>

<input type="file" id="file-input" accept=".json" style="display:none">

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── Map ──────────────────────────────────────────────────────────────
const map = L.map('map', {
  crs: L.CRS.Simple,
  minZoom: -8,
  zoomControl: true,
});
const bounds = [[0,0],[5120,3584]];
L.imageOverlay('cropped.webp', bounds).addTo(map);
map.fitBounds(bounds);

// ── State ────────────────────────────────────────────────────────────
let labels = [];        // [{id, name, tier, lat, lng, marker}]
let selectedId = null;
let editingId  = null;

// ── Label styles ─────────────────────────────────────────────────────
const STYLES = {
  region: {
    className: 'lbl-region',
    css: `font-family:Arial,sans-serif;font-size:18px;font-weight:900;
          color:white;text-shadow:0 0 6px rgba(0,0,0,0.9),0 0 12px rgba(0,0,0,0.7),
          2px 2px 0 rgba(0,0,0,0.8);letter-spacing:0.08em;text-transform:uppercase;
          pointer-events:auto;cursor:pointer;white-space:nowrap;`,
  },
  zone: {
    className: 'lbl-zone',
    css: `font-family:Arial,sans-serif;font-size:12px;font-weight:700;
          color:rgba(255,255,255,0.9);text-shadow:0 0 4px rgba(0,0,0,0.9),
          1px 1px 0 rgba(0,0,0,0.8);letter-spacing:0.04em;
          pointer-events:auto;cursor:pointer;white-space:nowrap;`,
  },
};

function makeDivIcon(name, tier) {
  const s = STYLES[tier];
  return L.divIcon({
    html: `<div style="${s.css}">${name}</div>`,
    className: '',
    iconAnchor: [0, 0],
    iconSize: null,
  });
}

// ── Add label ────────────────────────────────────────────────────────
function addLabel(lat, lng, name, tier, id) {
  id = id || Date.now() + Math.random();
  const marker = L.marker([lat, lng], {
    icon: makeDivIcon(name, tier),
    draggable: true,
    zIndexOffset: tier === 'region' ? 1000 : 500,
  }).addTo(map);

  marker.on('dragend', () => {
    const pos = marker.getLatLng();
    const entry = labels.find(l => l.id === id);
    if (entry) { entry.lat = pos.lat; entry.lng = pos.lng; }
    saveLocal();
  });
  marker.on('click', () => selectLabel(id));

  const entry = { id, name, tier, lat, lng, marker };
  labels.push(entry);
  renderList();
  saveLocal();
  return entry;
}

function removeLabel(id) {
  const idx = labels.findIndex(l => l.id === id);
  if (idx === -1) return;
  map.removeLayer(labels[idx].marker);
  labels.splice(idx, 1);
  if (selectedId === id) { selectedId = null; }
  if (editingId === id)  { cancelEdit(); }
  renderList();
  saveLocal();
}

function selectLabel(id) {
  selectedId = id;
  renderList();
  // Pan to it
  const entry = labels.find(l => l.id === id);
  if (entry) map.panTo([entry.lat, entry.lng]);
  startEdit(id);
}

// ── Edit ─────────────────────────────────────────────────────────────
function startEdit(id) {
  const entry = labels.find(l => l.id === id);
  if (!entry) return;
  editingId = id;
  document.getElementById('edit-name').value = entry.name;
  document.getElementById('edit-tier').value = entry.tier;
  document.getElementById('edit-panel').style.display = 'block';
}
function cancelEdit() {
  editingId = null;
  selectedId = null;
  document.getElementById('edit-panel').style.display = 'none';
  renderList();
}
document.getElementById('btn-edit-save').addEventListener('click', () => {
  const entry = labels.find(l => l.id === editingId);
  if (!entry) return;
  entry.name = document.getElementById('edit-name').value.trim() || entry.name;
  entry.tier = document.getElementById('edit-tier').value;
  entry.marker.setIcon(makeDivIcon(entry.name, entry.tier));
  cancelEdit();
  saveLocal();
});
document.getElementById('btn-edit-cancel').addEventListener('click', cancelEdit);

// ── Map click → place label ──────────────────────────────────────────
map.on('click', e => {
  if (editingId) return; // don't place while editing
  const name = document.getElementById('inp-name').value.trim();
  if (!name) {
    document.getElementById('mode-indicator').textContent = '⚠ Enter a label name first';
    document.getElementById('mode-indicator').style.color = '#e07050';
    setTimeout(() => {
      document.getElementById('mode-indicator').textContent = 'Click on the map to place a label';
      document.getElementById('mode-indicator').style.color = '#f0a040';
    }, 2000);
    return;
  }
  const tier = document.getElementById('inp-tier').value;
  addLabel(e.latlng.lat, e.latlng.lng, name, tier);
  // Clear name field after placing
  document.getElementById('inp-name').value = '';
});

// ── List render ──────────────────────────────────────────────────────
function renderList() {
  const list = document.getElementById('label-list');
  list.innerHTML = '';
  const sorted = [...labels].sort((a,b) => {
    if (a.tier !== b.tier) return a.tier === 'region' ? -1 : 1;
    return a.name.localeCompare(b.name);
  });
  sorted.forEach(entry => {
    const row = document.createElement('div');
    row.className = 'label-item' + (entry.id === selectedId ? ' selected' : '');
    row.innerHTML = `
      <span class="label-tier tier-${entry.tier}">${entry.tier}</span>
      <span class="label-name">${entry.name}</span>
      <button class="del-btn" title="Delete">✕</button>`;
    row.addEventListener('click', e => {
      if (e.target.classList.contains('del-btn')) { removeLabel(entry.id); return; }
      selectLabel(entry.id);
    });
    list.appendChild(row);
  });
  document.getElementById('status').textContent = `${labels.length} label${labels.length !== 1 ? 's' : ''}`;
}

// ── Export ───────────────────────────────────────────────────────────
document.getElementById('btn-export').addEventListener('click', () => {
  const data = labels.map(({ id, name, tier, lat, lng }) => ({ id, name, tier, lat, lng }));
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'regions.json';
  a.click();
  document.getElementById('status').textContent = `Exported ${data.length} labels`;
});

// ── Import ───────────────────────────────────────────────────────────
document.getElementById('btn-import').addEventListener('click', () => {
  document.getElementById('file-input').click();
});
document.getElementById('file-input').addEventListener('change', e => {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = evt => {
    try {
      const data = JSON.parse(evt.target.result);
      // Clear existing
      labels.forEach(l => map.removeLayer(l.marker));
      labels = [];
      data.forEach(({ id, name, tier, lat, lng }) => addLabel(lat, lng, name, tier, id));
      document.getElementById('status').textContent = `Imported ${data.length} labels`;
    } catch(err) {
      alert('Invalid JSON file');
    }
  };
  reader.readAsText(file);
  e.target.value = '';
});

// ── Clear all ────────────────────────────────────────────────────────
document.getElementById('btn-clear').addEventListener('click', () => {
  if (!labels.length || !confirm(`Delete all ${labels.length} labels?`)) return;
  labels.forEach(l => map.removeLayer(l.marker));
  labels = [];
  selectedId = null;
  cancelEdit();
  renderList();
  saveLocal();
});

// ── LocalStorage ─────────────────────────────────────────────────────
function saveLocal() {
  const data = labels.map(({ id, name, tier, lat, lng }) => ({ id, name, tier, lat, lng }));
  localStorage.setItem('regionEditorLabels', JSON.stringify(data));
}
function loadLocal() {
  try {
    const raw = localStorage.getItem('regionEditorLabels');
    if (!raw) return;
    const data = JSON.parse(raw);
    data.forEach(({ id, name, tier, lat, lng }) => addLabel(lat, lng, name, tier, id));
  } catch(e) {}
}

loadLocal();
renderList();
</script>
</body>
</html>
